# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

# PHP (app, integrations, etc.)
[*.php]
indent_size = 4

# Theme entrypoints & plain PHP at theme root
[{index.php,flexible.php,functions.php}]
indent_size = 2

# Blade (also covered by *.blade.php)
[*.blade.php]
indent_size = 2

# Frontend & tooling — TypeScript, JavaScript, Vue/Svelte if added
[*.{js,cjs,mjs,jsx,ts,mts,cts,tsx,vue,svelte}]
indent_size = 2

# Styles (Tailwind / CSS)
[*.{css,scss,sass,less}]
indent_size = 2

# Data & config commonly edited in the theme
[*.{json,yml,yaml}]
indent_size = 2

# Vite / Node config at theme root
[{vite.config.js,vitest.config.js,.prettierrc,.prettierrc.json}]
indent_size = 2
