{
  "mcpServers": {
    "bedrock-wp-acorn-cli": {
      "command": "node",
      "args": ["${workspaceFolder}/scripts/mcp-wp-acorn/index.mjs"],
      "cwd": "${workspaceFolder}",
      "env": {
        "BEDROCK_ROOT": "${workspaceFolder}"
      }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY:-}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "dotenv-cli",
        "-e",
        ".env",
        "--",
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ]
    },
    "perplexity": {
      "command": "npx",
      "args": ["-y", "@perplexity-ai/mcp-server"],
      "env": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY:-}"
      }
    }
  }
}
