# https://editorconfig.org — Bedrock repo (non-theme paths)
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.php]
indent_size = 4

[*.{json,yml,yaml}]
indent_size = 2

[*.{js,cjs,mjs,ts}]
indent_size = 2

[composer.json]
indent_size = 4
